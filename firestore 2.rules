rules_version = '2';
// LabelX Firestore rules.
// Reads/writes for config go through the server (Admin SDK), which bypasses
// these rules. These rules lock down any *direct* client access: a signed-in
// allow-listed user may read config, but only the server may write it.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }

    // Channels, styles, frames, sources, safetyRules, logos: read for any
    // signed-in user; writes only via Admin SDK (server), never from client.
    match /config/{doc=**} {
      allow read: if signedIn();
      allow write: if false;
    }

    // News cache + ephemeral sessions: server-managed only.
    match /articleCandidates/{doc} {
      allow read: if signedIn();
      allow write: if false;
    }
    match /sessions/{doc} {
      allow read, write: if false;
    }
  }
}
